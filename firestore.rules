rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regola globale: l'accesso è consentito solo agli utenti autenticati.
    // Essendo un'app single-tenant, tutti i collaboratori loggati condividono gli stessi dati.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
